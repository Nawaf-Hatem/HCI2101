<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>أحبك نواف</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #0d0d0d;
      color: #fff;
      font-family: monospace;
      font-size: 1.4em;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
    }
    #screen {
      text-align: center;
      white-space: pre;
    }
    .red  { color: #ff3355; font-weight: bold; }
    .mag  { color: #cc44ff; }
    #hint { margin-top: 30px; color: #aaa; font-size: 0.8em; }
    button {
      margin-top: 20px;
      padding: 10px 30px;
      font-size: 1em;
      background: #ff3355;
      color: white;
      border: none;
      border-radius: 8px;
      cursor: pointer;
    }
    button:hover { background: #cc0033; }
  </style>
</head>
<body>

<div id="screen"></div>
<div id="hint">اضغط الزر للتبديل</div>
<button onclick="toggle()">تبديل ❤</button>

<script>
  let heartsOn = true;
  const name = "نواف";

  function render() {
    const screen = document.getElementById("screen");
    if (heartsOn) {
      screen.innerHTML =
        `<span class="red">❤  أحبك ${name}  ❤</span>\n` +
        `<span class="mag">♡ ♥ ❤ ♡ ♥ ❤ ♡</span>`;
    } else {
      screen.innerHTML =
        `<strong>أحبك ${name}</strong>`;
    }
  }

  function toggle() {
    heartsOn = !heartsOn;
    render();
  }

  render();
</script>
</body>
</html>